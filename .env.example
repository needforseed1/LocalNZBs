PROVIDER_NAME=LocalNZBs

# API key for Newznab requests from Prowlarr/AIOStreams.
# Required: /api returns 403 until this is changed from change-me.
# Generate one with: openssl rand -hex 32
API_KEY=change-me

# Upload key for PUT /nzb/{filename}. Upload stays disabled while this is
# unset or left at change-me-too. Generate one with: openssl rand -hex 32
UPLOAD_KEY=change-me-too

# BASE_URL=http://localhost:8000
REFRESH_SECONDS=10
MAX_UPLOAD_BYTES=104857600
