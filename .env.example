PROVIDER_NAME=LocalNZBs

# API key for Newznab requests from Prowlarr/AIOStreams.
# Required: /api returns 403 until this is changed from change-me.
# Generate one with: openssl rand -hex 32
API_KEY=change-me

# BASE_URL=http://localhost:8000
REFRESH_SECONDS=10

# Password for the web UI at /ui. Leave unset to disable the UI entirely.
# Deleting via the UI moves NZBs to TRASH_DIR and requires a writable (:rw) mount.
# UI_PASSWORD=
# TRASH_DIR=/nzbs/.trash
